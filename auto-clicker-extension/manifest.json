{
  "manifest_version": 3,
  "name": "Tab Auto Clicker",
  "version": "1.0.0",
  "description": "Find and click an element in the current tab at interval.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Clicker"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
